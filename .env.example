# Copy to .env and fill in. NEVER commit .env.

# ServiceTitan (read-only credentials)
SERVICETITAN_CLIENT_ID=replace_me
SERVICETITAN_CLIENT_SECRET=replace_me
SERVICETITAN_APP_KEY=replace_me
SERVICETITAN_TENANT_ID=replace_me
SERVICETITAN_TIMEZONE=America/Chicago

# Email delivery
SENDGRID_API_KEY=replace_me
SENDGRID_FROM_EMAIL=replace_me@yourdomain.com
SENDGRID_FROM_NAME=LEX Reporting

# Photo vision (via OpenRouter)
OPENROUTER_API_KEY=replace_me
LEX_BRIEF_VISION_MODEL=openai/gpt-4o
LEX_BRIEF_MODEL=openai/gpt-4o
